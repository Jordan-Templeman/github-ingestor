#!/bin/bash -e

# Ensure gems match the volume-mounted Gemfile.lock
bundle install --quiet

# Remove stale PID file if it exists
rm -f /rails/tmp/pids/server.pid

# Prepare the database (create + migrate if needed)
# Fallback to db:migrate if db:prepare fails (e.g. race with another container)
./bin/rails db:prepare || ./bin/rails db:migrate

exec "${@}"
